# ============================================
# FidesOrigin 环境变量配置
# ============================================
# 复制此文件为 .env 并根据需要修改
# ============================================

# ============================================
# PostgreSQL 配置
# ============================================
POSTGRES_USER=fidesorigin
POSTGRES_PASSWORD=fidesorigin_secret_2026
POSTGRES_DB=fidesorigin
POSTGRES_PORT=5432

# ============================================
# Redis 配置
# ============================================
REDIS_PASSWORD=redis_secret_2026
REDIS_PORT=6379

# ============================================
# pgAdmin 配置
# ============================================
PGADMIN_EMAIL=admin@fidesorigin.com
PGADMIN_PASSWORD=admin_secret_2026
PGADMIN_PORT=5050

# ============================================
# Adminer 配置 (可选)
# ============================================
ADMINER_PORT=8080

# ============================================
# Redis Commander 配置 (可选)
# ============================================
REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=admin_secret_2026
REDIS_COMMANDER_PORT=8081

# ============================================
# 监控配置 (可选)
# ============================================
PROMETHEUS_PORT=9090
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin_secret_2026
GRAFANA_ROOT_URL=http://localhost:3000
GRAFANA_PORT=3000

# ============================================
# 备份配置
# ============================================
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7

# ============================================
# 数据目录
# ============================================
DATA_DIR=./data
