# Deployment Environment Variables

# Required: Private key for deployment (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# RPC Endpoints
SEPOLIA_RPC=https://rpc.sepolia.org
GOERLI_RPC=https://rpc.goerli.eth.gateway.fm

# Optional: Etherscan API Key for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key

# Optional: Alchemy or Infura RPC for better reliability
# SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# GOERLI_RPC=https://eth-goerli.g.alchemy.com/v2/YOUR_API_KEY
