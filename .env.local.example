# FidesOrigin 前端环境变量配置

# API 基础地址（开发环境使用代理，生产环境使用实际域名）
NEXT_PUBLIC_API_BASE_URL=/api

# WebSocket 服务器地址
NEXT_PUBLIC_WS_URL=wss://api.fidesorigin.com/ws

# 风险分析 API 端点
NEXT_PUBLIC_RISK_API_URL=/api/risk

# 规则配置 API 端点  
NEXT_PUBLIC_RULES_API_URL=/api/rules

# 仪表盘数据 API
NEXT_PUBLIC_DASHBOARD_API_URL=/api/dashboard

# 可选：Etherscan API Key（用于增强地址查询）
# NEXT_PUBLIC_ETHERSCAN_API_KEY=your_etherscan_api_key

# 可选：后端服务直接地址（用于服务器端调用）
# API_BASE_URL=https://api.fidesorigin.com
