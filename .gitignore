# Build artifacts
/build/
/dist/
**/dist/
*.tsbuildinfo

# Dependencies
/node_modules/
**/node_modules/
/.pnpm/
.pnpm-store/

# Environment
# [Low Fix #66] .env files are properly gitignored.
# SECURITY: Never commit real secret values. Always use placeholders.
# Environment files (.env, .env.local, .env.*.local) contain sensitive data.
.env
.env.local
.env.*.local

# Testing & Coverage
/coverage/

# Framework
/.next/
/.turbo/
/.vercel/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# Backup
*.bak.js
*.tmp.js

# Contract build artifacts
apps/contracts/artifacts/
apps/contracts/cache/
apps/contracts/typechain-types/
apps/contracts/typechain/
apps/contracts/deployments/*/solcInputs/

# Subgraph build
apps/subgraph/build/
apps/subgraph/generated/
apps/subgraph/node_modules/

# Data sync
/data-sync/node_modules/
/data-sync/dist/
/data-sync/prisma/migrations/
/data-sync/db/

# API
/apps/api/.next/
/apps/api/dist/

# Misc
packages/*/dist/
packages/*/node_modules/

# Forta agents
forta-agents/*/dist/
forta-agents/*/node_modules/

# Deployment artifacts
deployments/

# Hardhat build artifacts (contain full ABI — information exposure risk)
apps/contracts/artifacts/

# K8s secrets
k8s/secret.yaml

# Data sync env
data-sync/.env

# Wallet files (contain sensitive mnemonic phrases)
.wallet-*.json

# [L-29/L-30 Fix] Additional sensitive file patterns
*.key
*.pem
*.p12
*.pfx
*.crt
.ssh/
.vercel/
.env.glm52
*.env.*
