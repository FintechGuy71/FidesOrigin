#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/root/.openclaw/workspace/fidesorigin-demo/node_modules/.pnpm/typechain@8.3.2_supports-color@8.1.1_typescript@5.9.3/node_modules/typechain/node_modules:/root/.openclaw/workspace/fidesorigin-demo/node_modules/.pnpm/typechain@8.3.2_supports-color@8.1.1_typescript@5.9.3/node_modules:/root/.openclaw/workspace/fidesorigin-demo/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/root/.openclaw/workspace/fidesorigin-demo/node_modules/.pnpm/typechain@8.3.2_supports-color@8.1.1_typescript@5.9.3/node_modules/typechain/node_modules:/root/.openclaw/workspace/fidesorigin-demo/node_modules/.pnpm/typechain@8.3.2_supports-color@8.1.1_typescript@5.9.3/node_modules:/root/.openclaw/workspace/fidesorigin-demo/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../typechain/dist/cli/cli.js" "$@"
else
  exec node  "$basedir/../typechain/dist/cli/cli.js" "$@"
fi
