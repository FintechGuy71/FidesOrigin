# FidesOrigin 环境变量配置示例
# 复制此文件为 .env 并修改配置

# 应用配置
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-change-in-production

# 数据库配置
DATABASE_URL=postgresql+asyncpg://fidesorigin:fidesorigin_pass@localhost:5432/fidesorigin
DATABASE_URL_SYNC=postgresql://fidesorigin:fidesorigin_pass@localhost:5432/fidesorigin

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# Blockscout API 配置
BLOCKSCOUT_API_KEY=your-blockscout-api-key
BLOCKSCOUT_BASE_URL=https://eth.blockscout.com/api/v2
BLOCKSCOUT_TIMEOUT=30

# 风险引擎配置
RISK_CACHE_TTL=300

# CORS 配置（开发环境）
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
