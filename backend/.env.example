# ============================================================
# FidesOrigin Production Environment Variables
# 复制此文件为 .env 并填入实际值后部署
# ============================================================

# ==================== 应用基础配置 ====================
APP_NAME=FidesOrigin
APP_VERSION=2.0.0
# 必须是 production，否则安全校验会失败
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# ==================== 数据库配置 ====================
# 这些在 docker-compose 中会被覆盖为服务名，但本地调试时有用
DB_HOST=postgres
DB_PORT=5432
DB_USER=fidesorigin
# ⚠️ 生产环境必须设置强密码（不要留空）
DB_PASSWORD=YOUR_STRONG_DB_PASSWORD_HERE
DB_NAME=fidesorigin
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# 同步数据库 URL（Alembic 迁移使用）
# 格式: postgresql://user:password@host:port/dbname
DATABASE_URL_SYNC_VALUE=postgresql://fidesorigin:YOUR_STRONG_DB_PASSWORD_HERE@postgres:5432/fidesorigin

# ==================== Redis 配置 ====================
REDIS_HOST=redis
REDIS_PORT=6379
# ⚠️ 生产环境建议设置 Redis 密码
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false
REDIS_POOL_SIZE=50
REDIS_POOL_TIMEOUT=10

# ==================== 安全密钥（必须设置） ====================
# ⚠️ 生产环境必须设置 32 位以上随机字符串
SECRET_KEY=YOUR_32CHAR_PLUS_RANDOM_SECRET_KEY_HERE_CHANGE_THIS
# ⚠️ API 密钥，用于外部调用认证
API_KEY=YOUR_API_KEY_HERE_CHANGE_THIS
# ⚠️ HMAC 签名密钥，用于请求签名验证
HMAC_SECRET=YOUR_HMAC_SECRET_KEY_HERE_CHANGE_THIS
HMAC_ENABLED=true

# ==================== Admin 密码（必须设置） ====================
# ⚠️ 生产环境必须满足以下要求：
# - 至少 12 位字符
# - 包含至少 1 个大写字母
# - 包含至少 1 个小写字母
# - 包含至少 1 个数字
# - 包含至少 1 个特殊字符 (!@#$%^&*()_+-=[]{};':",.<>/?)
ADMIN_PASSWORD=Your_Str0ng!AdminP@ssw0rd

# ==================== CORS 配置 ====================
# 生产环境逗号分隔，不允许使用 *
CORS_ORIGINS=https://fidesorigin.com,https://www.fidesorigin.com,https://fidesorigin-demo.vercel.app
CORS_ALLOW_CREDENTIALS=true

# ==================== Blockscout 配置 ====================
BLOCKSCOUT_BASE_URL=https://eth.blockscout.com/api/v2
BLOCKSCOUT_API_KEY=
BLOCKSCOUT_TIMEOUT=30
BLOCKSCOUT_RATE_LIMIT=5

# ==================== 风险引擎配置 ====================
RISK_CACHE_TTL=300
RISK_ENGINE_TIMEOUT=30

# ==================== 监控 / WebSocket 配置 ====================
MONITOR_WS_PING_INTERVAL=30
MONITOR_MAX_CONNECTIONS=100

# ==================== 告警配置 ====================
ALERT_ENABLED=false
ALERT_WEBHOOK_URL=
ALERT_COOLDOWN_MINUTES=5

# ==================== 速率限制配置 ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
