# FidesOrigin Data Publisher
# Self-hosted on-chain data publishing service

# =====================================
# Environment
# =====================================
NODE_ENV=production
LOG_LEVEL=info

# =====================================
# Blockchain Connection (Sepolia)
# =====================================
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
CHAIN_ID=11155111
RISK_REGISTRY_ADDRESS=0x7a41abE5B170085fDe9d4e0a3BaD47A70bAC52bc

# =====================================
# Key Management (choose ONE)
# =====================================
# Option A: Plain private key (development/testing ONLY)
# PUBLISHER_PRIVATE_KEY=0x...
# 
# Option B: AWS KMS (production)
# KMS_PROVIDER=aws
# KMS_KEY_ID=arn:aws:kms:us-east-1:123456789:key/your-key-id
#
# Option C: HashiCorp Vault (production / fallback)
# KMS_PROVIDER=vault
# VAULT_ADDR=https://vault.example.com:8200
# VAULT_SECRET_PATH=secret/data/fidesorigin
# VAULT_KEY_NAME=privateKey
# VAULT_TOKEN=s.yourVaultToken
#
# Option D: Azure Key Vault (legacy)
# KMS_PROVIDER=azure
# KMS_KEY_ID=https://your-vault.vault.azure.net/keys/your-key-name

# =====================================
# Gas Configuration
# =====================================
GAS_LIMIT=300000
MAX_FEE_PER_GAS=50
MAX_PRIORITY_FEE_PER_GAS=2
BATCH_SIZE=50
TX_INTERVAL_MS=2000
DRY_RUN=false

# =====================================
# Data Sources
# =====================================
OFAC_ENABLED=true
OFAC_ENDPOINT=https://www.treasury.gov/ofac/downloads/sdn.xml
OFAC_WEIGHT=1.0
OFAC_TIMEOUT=30000
OFAC_RETRY=3
OFAC_CRON=0 0 * * *

CHAINALYSIS_ENABLED=false
CHAINALYSIS_ENDPOINT=https://api.chainalysis.com/api/v1/
CHAINALYSIS_API_KEY=
CHAINALYSIS_WEIGHT=1.0
CHAINALYSIS_TIMEOUT=30000
CHAINALYSIS_RETRY=3
CHAINALYSIS_CRON=0 */6 * * *

OPENSANCTIONS_ENABLED=true
OPENSANCTIONS_ENDPOINT=https://api.opensanctions.org/
OPENSANCTIONS_API_KEY=
OPENSANCTIONS_WEIGHT=1.0
OPENSANCTIONS_TIMEOUT=30000
OPENSANCTIONS_RETRY=3
OPENSANCTIONS_CRON=0 0 * * *

ETHERSCAN_ENABLED=false
ETHERSCAN_ENDPOINT=https://api.etherscan.io/api
ETHERSCAN_API_KEY=
ETHERSCAN_WEIGHT=0.5
ETHERSCAN_TIMEOUT=30000
ETHERSCAN_RETRY=3
ETHERSCAN_CRON=0 0 * * 0

# =====================================
# Scheduler
# =====================================
FULL_SYNC_CRON=0 2 * * *
INCREMENTAL_SYNC_CRON=0 */4 * * *

# =====================================
# FATF Pipeline (weekly — country risk + address enrichment)
# =====================================
FATF_ENABLED=true
FATF_CRON=17 3 * * 1
FATF_USE_FALLBACK=true
FATF_DRY_RUN=true
OFAC_FETCH_TIMEOUT=120000

# FATF Oracle account (separate ORACLE_ROLE deployer for FATF data)
FATF_ORACLE_PRIVATE_KEY=
FATF_RISK_REGISTRY_ADDRESS=0x7a41abE5B170085fDe9d4e0a3BaD47A70bAC52bc
FATF_GAS_LIMIT=300000

# =====================================
# Monitoring & Alerting
# =====================================
MONITOR_ENABLED=true
MONITOR_PORT=9090
MONITOR_METRICS_PATH=/metrics
MONITOR_HEALTH_PATH=/health
ALERT_WEBHOOK_URL=
# Supported: Slack (hooks.slack.com), Discord (discord.com/api/webhooks),
# DingTalk (oapi.dingtalk.com), generic webhook
