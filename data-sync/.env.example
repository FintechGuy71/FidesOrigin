# FidesOrigin Risk Sync Environment Variables

# ============================================
# 区块链连接配置
# ============================================

# Sepolia 测试网 RPC (推荐使用 Alchemy 或 Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# 或
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# 部署者私钥 (带 0x 前缀)
PRIVATE_KEY=0x1234567890abcdef...

# ============================================
# 合约地址 (部署后填写)
# ============================================

# RiskOracle 合约地址
RISK_ORACLE_ADDRESS=0x...

# RiskRegistry 合约地址 (可选)
RISK_REGISTRY_ADDRESS=0x...

# ============================================
# Chainlink Functions 配置
# ============================================

# Chainlink Functions Subscription ID
CHAINLINK_SUBSCRIPTION_ID=123

# Chainlink Functions DON ID (Sepolia)
CHAINLINK_DON_ID=fun-ethereum-sepolia-1

# Chainlink Functions Router (Sepolia)
CHAINLINK_FUNCTIONS_ROUTER=0xb83E47C2bC239B3bf370bc41e1459A34b41238D0

# ============================================
# API Keys (可选)
# ============================================

# Etherscan API Key (用于链上数据分析)
ETHERSCAN_API_KEY=...

# Chainalysis API Key (可选)
CHAINALYSIS_API_KEY=...

# TRM Labs API Key (可选)
TRM_API_KEY=...

# Elliptic API Key (可选)
ELLIPTIC_API_KEY=...

# ============================================
# 自定义 API 端点 (可选)
# ============================================

# FidesOrigin 自定义风险 API
FIDES_RISK_API_URL=https://api.fidesorigin.io/risk

# ============================================
# 通知配置 (可选)
# ============================================

# Slack Webhook (用于同步失败通知)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Email 通知 (使用 SendGrid)
SENDGRID_API_KEY=...
ALERT_EMAIL=admin@fidesorigin.com
