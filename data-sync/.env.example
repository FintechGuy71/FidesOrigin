# 数据库连接
DATABASE_URL="postgresql://user:password@localhost:5432/fidesorigin?schema=public"

# Chainalysis API
CHAINALYSIS_API_KEY="your_chainalysis_api_key_here"

# 慢雾 MistTrack API
MISTTRACK_API_KEY="your_misttrack_api_key_here"

# 区块链配置（用于链上同步）
RPC_URL="https://sepolia.infura.io/v3/YOUR_INFURA_KEY"
SYNC_PRIVATE_KEY="your_wallet_private_key_for_syncing"
RISK_REGISTRY_CONTRACT="0x..."

# 可选配置
LOG_LEVEL="info"
SYNC_BATCH_SIZE="50"
