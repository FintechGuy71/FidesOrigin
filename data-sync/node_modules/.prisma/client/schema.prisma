// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 风险地址主表
model RiskAddress {
  id        String  @id @default(cuid())
  address   String  @unique // 区块链地址 (小写存储)
  chain     String  @default("ethereum") // 链类型
  category  String // 分类: BLACKLIST/GRAYLIST/WHITELIST/UNKNOWN
  label     String // 标签: high_risk/medium_risk/low_risk/unknown
  riskScore Int     @default(0) // 综合风险评分 0-100
  tags      String // 风险标签列表 (JSON数组)
  sources   String // 数据来源 (JSON数组)
  metadata  String? // 各数据源的原始元数据 (JSON)

  // 同步状态
  syncedToChain Boolean   @default(false)
  syncedAt      DateTime?

  // 时间戳
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([syncedToChain])
  @@index([riskScore])
  @@index([chain])
  @@map("risk_addresses")
}

// 同步日志
model SyncLog {
  id             String   @id @default(cuid())
  timestamp      DateTime @default(now())
  source         String // 数据源名称
  addressesCount Int
  newCount       Int // 新增数量
  updatedCount   Int // 更新数量
  status         String // SUCCESS/FAILED/ERROR/PARTIAL
  details        String?

  @@index([timestamp])
  @@index([source])
  @@index([status])
  @@map("sync_logs")
}

// 数据源配置
model DataSourceConfig {
  id           String    @id @default(cuid())
  name         String    @unique // chainalysis/ofac/open_source
  enabled      Boolean   @default(true)
  apiKey       String?
  apiUrl       String?
  lastSync     DateTime?
  requestCount Int       @default(0) // 今日请求计数

  updatedAt DateTime @updatedAt

  @@map("data_source_configs")
}
