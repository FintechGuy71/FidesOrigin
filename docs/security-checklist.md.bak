#### Forta Agent Configuration

```typescript
// forta-agents/risk-update/agent.ts
import { Finding, FindingSeverity, FindingType, HandleTransaction } from 'forta-agent';

const RISK_REGISTRY = '0x7a41abE5B170085fDe9d4e0a3BaD47A70bAC52bc';
const RISK_PROFILE_UPDATED_EVENT = 'event RiskProfileUpdated(address indexed target, uint256 riskScore, uint8 tier, bool sanctioned, uint256 timestamp)';

export const handleTransaction: HandleTransaction = async (txEvent) => {
  const findings: Finding[] = [];
  
  const events = txEvent.filterLog(RISK_PROFILE_UPDATED_EVENT, RISK_REGISTRY);
  
  for (const event of events) {
    const { target, riskScore, tier, sanctioned } = event.args;
    
    // Alert on critical tier updates
    if (tier === 4) {
      findings.push(Finding.fromObject({
        name: 'FidesOrigin Critical Risk Profile Update',
        description: `Address ${target} updated to CRITICAL tier (score: ${riskScore})`,
        alertId: 'FIDESORIGIN-CRITICAL-RISK-1',
        severity: FindingSeverity.Critical,
        type: FindingType.Suspicious,
        metadata: {
          target,
          riskScore: riskScore.toString(),
          tier: tier.toString(),
          sanctioned: sanctioned.toString(),
          txHash: txEvent.hash,
        },
      }));
    }
    
    // Alert on sanctioned updates
    if (sanctioned) {
      findings.push(Finding.fromObject({
        name: 'FidesOrigin Sanctioned Address Update',
        description: `Address ${target} marked as sanctioned`,
        alertId: 'FIDESORIGIN-SANCTIONED-1',
        severity: FindingSeverity.High,
        type: FindingType.Suspicious,
        metadata: {
          target,
          riskScore: riskScore.toString(),
          txHash: txEvent.hash,
        },
      }));
    }
  }
  
  return findings;
};
```

