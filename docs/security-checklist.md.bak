### 2.4 On-Chain Monitoring (Custom)

```python
# monitoring/onchain_monitor.py
import asyncio
from web3 import Web3
from dataclasses import dataclass
from typing import List, Callable

@dataclass
class Alert:
    severity: str  # critical, high, medium, low
    title: str
    description: str
    metadata: dict

class OnChainMonitor:
    def __init__(self, rpc_url: str, contracts: dict):
        self.w3 = Web3(Web3.HTTPProvider(rpc_url))
        self.contracts = contracts
        self.alert_handlers: List[Callable[[Alert], None]] = []
        
    async def monitor_events(self):
        """Monitor all contract events in real-time"""
        while True:
            for name, contract in self.contracts.items():
                # Poll for new events
                events = contract.events.createFilter(fromBlock='latest')
                for event in events.get_new_entries():
                    await self._process_event(name, event)
            await asyncio.sleep(12)  # ~1 block on Ethereum
    
    async def _process_event(self, contract_name: str, event):
        """Process and alert on critical events"""
        event_name = event.event
        
        if event_name == 'Upgraded':
            await self._alert(Alert(
                severity='critical',
                title=f'{contract_name} UUPS Upgrade Detected',
                description=f'New implementation: {event.args.implementation}',
                metadata={'tx': event.transactionHash.hex(), 'implementation': event.args.implementation}
            ))
        
        elif event_name == 'RiskProfileUpdated' and event.args.tier == 4:
            await self._alert(Alert(
                severity='critical',
                title='CRITICAL Risk Profile Update',
                description=f'Address {event.args.target} promoted to CRITICAL',
                metadata={'target': event.args.target, 'score': event.args.riskScore}
            ))
        
        elif event_name == 'RoleGranted':
            # Verify the sender is the role admin
            contract = self.contracts[contract_name]
            role_admin = contract.functions.getRoleAdmin(event.args.role).call()
            if not contract.functions.hasRole(role_admin, event.args.sender).call():
                await self._alert(Alert(
                    severity='critical',
                    title='Unauthorized Role Grant Detected',
                    description=f'Role {event.args.role.hex()} granted by non-admin',
                    metadata={'role': event.args.role.hex(), 'account': event.args.account, 'sender': event.args.sender}
                ))
    
    async def _alert(self, alert: Alert):
        for handler in self.alert_handlers:
            handler(alert)
    
    def add_alert_handler(self, handler: Callable[[Alert], None]):
        self.alert_handlers.append(handler)

# Usage
monitor = OnChainMonitor(
    rpc_url='https://rpc.sepolia.org',
    contracts={
        'RiskRegistry': risk_registry_contract,
        'PolicyEngine': policy_engine_contract,
        'ComplianceEngine': compliance_engine_contract,
        'QuarantineVault': quarantine_vault_contract,
    }
)

# Add Slack handler
monitor.add_alert_handler(slack_handler)
monitor.add_alert_handler(pagerduty_handler)
monitor.add_alert_handler(email_handler)

asyncio.run(monitor.monitor_events())
```

