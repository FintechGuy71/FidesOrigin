#### Tenderly Alert Rules

```yaml
# tenderly-alerts.yaml
alerts:
  - name: "UUPS Upgrade Detected"
    contract: "RiskRegistry"
    event: "Upgraded(address indexed implementation)"
    severity: critical
    channels: [slack, email, pagerduty]
    
  - name: "Large Quarantine Release"
    contract: "QuarantineVault"
    function: "releaseFunds(address,uint256)"
    condition: "amount > 100 * 10^18"  # > 100 ETH
    severity: high
    channels: [slack, email]
    
  - name: "Role Granted by Non-Admin"
    contract: "RiskRegistry"
    event: "RoleGranted(bytes32 indexed role, address indexed account, address indexed sender)"
    condition: "!hasRole(getRoleAdmin(role), sender)"
    severity: critical
    channels: [slack, email, pagerduty]
    
  - name: "Oracle Inactive > 24h"
    contract: "RiskRegistry"
    condition: "timeSinceLastEvent('RiskProfileUpdated') > 86400"
    severity: medium
    channels: [slack]
    
  - name: "Contract Pause"
    contract: "CompliantStableCoin"
    event: "Paused(address account)"
    severity: high
    channels: [slack, email, pagerduty]
    
  - name: "Unexpected ETH Transfer"
    contract: "QuarantineVault"
    function: "receive()"
    condition: "msg.value > 10 * 10^18"  # > 10 ETH
    severity: medium
    channels: [slack]
```

