{
  "name": "fidesorigin",
  "version": "0.2.1",
  "private": true,
  "description": "FidesOrigin — Programmable On-Chain Compliance Protocol (Monorepo)",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "postinstall": "pnpm build --filter=@fidesorigin/shared --filter=@fidesorigin/config"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "prettier": "^3.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "turbo": "^2.5.0",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.6.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "@napi-rs/canvas",
      "secp256k1",
      "keccak",
      "bcrypt",
      "esbuild",
      "protobufjs"
    ],
    "overrides": {
      "@chainlink/contracts": "1.3.0"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@chainlink/contracts": "^1.3.0",
    "immer": "^11.1.8",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  }
}
