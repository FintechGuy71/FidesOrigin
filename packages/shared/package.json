{
  "name": "@fidesorigin/shared",
  "version": "0.2.1",
  "description": "Shared types, constants, and KMS signer for FidesOrigin",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "default": "./dist/constants/index.js"
    },
    "./kms": {
      "types": "./dist/kms/index.d.ts",
      "default": "./dist/kms/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "ethers": "^6.13.0",
    "@aws-sdk/client-kms": "^3.600.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
