# FidesOrigin Keeper Cron 配置
# 添加到 crontab: crontab -e

# 每 5 分钟检查 keeper 是否在运行，如崩溃则自动重启
*/5 * * * * cd /root/.openclaw/workspace/fidesorigin-demo && scripts/start-keeper.sh status >/dev/null || scripts/start-keeper.sh start >/dev/null 2>&1

# 每小时跑一次 daily-sync（更新风险数据并上链）
0 * * * * cd /root/.openclaw/workspace/fidesorigin-demo && node data-sync/scripts/daily-sync.js >> /tmp/fidesorigin-sync.log 2>&1

# 每天凌晨 3 点重启 keeper（防止内存泄漏）
0 3 * * * cd /root/.openclaw/workspace/fidesorigin-demo && scripts/start-keeper.sh restart >/dev/null 2>&1
