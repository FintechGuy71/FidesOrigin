specVersion: 1.0.0
indexerHints:
  prune: auto
schema:
  file: ./schema.graphql
dataSources:
  - kind: ethereum
    name: RiskRegistry
    network: sepolia
    source:
      abi: RiskRegistry
      address: "0xdA4D86D812b4AdF3e0023a6D4b1FF20139abD3b3"
      startBlock: 10819500
    mapping:
      kind: ethereum/events
      apiVersion: 0.0.9
      language: wasm/assemblyscript
      entities:
        - RiskProfile
        - RiskProfileUpdate
        - SanctionedAddress
      abis:
        - name: RiskRegistry
          file: ./abis/RiskRegistry.json
      eventHandlers:
        - event: RiskProfileUpdated(indexed address,uint8,uint8,bool)
          handler: handleRiskProfileUpdated
        - event: AddressTagged(indexed address,indexed bytes32)
          handler: handleAddressTagged
        - event: SanctionAdded(indexed address,string)
          handler: handleSanctionAdded
        - event: SanctionRemoved(indexed address)
          handler: handleSanctionRemoved
        - event: ContractRegistered(indexed address,bytes32,bool)
          handler: handleContractRegistered
      file: ./src/mappings/riskRegistry.ts
  - kind: ethereum
    name: ComplianceEngine
    network: sepolia
    source:
      abi: ComplianceEngine
      address: "0xd978f3246c56d7E3c3fF326e9fDe539f91F39ACa"
      startBlock: 10819500
    mapping:
      kind: ethereum/events
      apiVersion: 0.0.9
      language: wasm/assemblyscript
      entities:
        - ComplianceCheck
        - HoldRecord
        - OperationLog
        - ProtocolStats
        - DailyStats
        - HourlyStats
      abis:
        - name: ComplianceEngine
          file: ./abis/ComplianceEngine.json
      eventHandlers:
        - event: ComplianceCheck(indexed address,indexed address,indexed
            address,uint256,uint8,string)
          handler: handleComplianceCheck
        - event: FundsHeld(indexed bytes32,indexed address,address,uint256)
          handler: handleFundsHeld
        - event: FundsReleased(indexed bytes32,indexed address,uint256)
          handler: handleFundsReleased
        - event: EmergencyModeActivated(indexed address)
          handler: handleEmergencyModeActivated
        - event: EmergencyModeDeactivated(indexed address)
          handler: handleEmergencyModeDeactivated
      file: ./src/mappings/complianceEngine.ts
  - kind: ethereum
    name: PolicyEngine
    network: sepolia
    source:
      abi: PolicyEngine
      address: "0xF8f89120f5628aE3De747f55e7d00D79633002c4"
      startBlock: 10819500
    mapping:
      kind: ethereum/events
      apiVersion: 0.0.9
      language: wasm/assemblyscript
      entities:
        - Policy
        - PolicyVersion
      abis:
        - name: PolicyEngine
          file: ./abis/PolicyEngine.json
      eventHandlers:
        - event: IssuerPolicySet(indexed
            address,(uint256,uint256,bool,bool,bool,bool,uint256))
          handler: handleIssuerPolicySet
        - event: WalletPolicySet(indexed
            address,(uint256,uint256,uint256,uint256,bool,bool,bool,address[],address[]))
          handler: handleWalletPolicySet
        - event: PolicyEvaluated(indexed address,indexed address,indexed
            address,uint256,uint8,string)
          handler: handlePolicyEvaluated
      file: ./src/mappings/policyEngine.ts
templates: []